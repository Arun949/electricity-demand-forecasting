# Environments
venv/
.venv/
__pycache__/
*.pyc

# Secrets
.env

# Data (raw/processed are regenerated by the pipeline)
data/raw/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
# ...except the two files the deployed Streamlit app reads directly, so a
# fresh deploy (no pipeline run, no ENTSOE_API_KEY) can still serve the
# dashboard and "Ask the Model" from committed, pre-computed artifacts.
!data/processed/combined_data.csv
!data/processed/test_data.csv

# Models & artifacts
models/*.pkl
!models/best_model.pkl
!models/scaler.pkl
outputs/*.png
!outputs/04_bias_variance_tradeoff.png
!outputs/05_feature_importance.png
mlruns.db
mlruns/
mlartifacts/

