# Copy this file to .env and fill in real values.
# Register for a free ENTSO-E key at https://transparency.entsoe.eu/
# (Account Settings -> Web Api Security Token). Without it, data_collection.py
# falls back to a labeled synthetic demand series so the rest of the pipeline
# is still runnable end to end.
ENTSOE_API_KEY=

# Weather comes from Open-Meteo (https://open-meteo.com/), which is free and
# keyless, so no weather key is required.
